// LocalBuild.xcconfig
// Build configuration for local/unsigned builds (no Apple Developer certificate required).
// Used by `make local` — does NOT affect Debug or Release configurations.

// Apple Development signing with personal team (stable identity across rebuilds → TCC honors grants)
CODE_SIGN_IDENTITY = Apple Development
CODE_SIGN_STYLE = Automatic
DEVELOPMENT_TEAM = H7NUTZB93F
PROVISIONING_PROFILE_SPECIFIER =

// Entitlements are set via absolute path in the Makefile command line
// (relative paths break SPM package targets that resolve from their own source root)

// Add LOCAL_BUILD compilation flag so Swift code can use #if LOCAL_BUILD
SWIFT_ACTIVE_COMPILATION_CONDITIONS = $(inherited) LOCAL_BUILD
